<!DOCTYPE html>
<html lang="en">

<head>
    {% include "partials/head.j2" %}
    <title>Feeds | rdr</title>
</head>

<body>
    <main id="app">
        <h1>Feeds</h1>
        {% include "partials/nav.j2" %}
        <blockquote>
            <div>{{ categories.len() }} categories found.</div>
        </blockquote>
        <table>
            <tr>
                <th>Category</th>
                <th>Feed</th>
                <th>Action</th>
            </tr>
            {% for category in categories %}
            <tr>
                <td rowspan="{{ category.feeds_count() + 1 }}">
                    <div>
                        {{ category.name() }}
                        <code>{{ category.feeds_count() }} feeds</code>
                    </div>
                    <div>&nbsp;</div>
                    <div>
                        <button class="refresh-category"
                            data-category-id="{{ category.generate_id() }}">Refresh</button>
                    </div>
                </td>
            </tr>
            {% for feed in category.feeds %}
            <x-feed feed-id="{{ feed.generate_id() }}">
                <tr>
                    <td>
                        <a href="{{ feed.html_url() }}" target="_blank" rel="noopener noreferrer">{{ feed.title }}</a>
                    </td>
                    <td>
                        <button class="refresh-feed" data-category-id="{{ category.generate_id() }}"
                            data-feed-id="{{ feed.generate_id() }}">Refresh</button>
                    </td>
                </tr>
            </x-feed>
            {% endfor %}
            {% endfor %}
        </table>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll(".refresh-category").forEach(button => {
                button.addEventListener("click", async (event) => {
                    const categoryId = event.target.getAttribute("data-category-id");
                    if (!categoryId) return;

                    button.disabled = true;
                    button.textContent = "Refreshing...";
                    document.querySelectorAll(`.refresh-feed[data-category-id='${categoryId}']`).forEach(feedButton => {
                        feedButton.disabled = true;
                        feedButton.textContent = "Refreshing...";
                    });
                    try {
                        const response = await fetch(`/api/categories/${categoryId}/refresh`, {
                            method: "GET",
                            headers: {
                                "Content-Type": "application/json"
                            }
                        });
                        if (response.ok) {
                            const result = await response.json();
                            console.log(`Category refreshed successfully: ${JSON.stringify(result)}`);
                        } else {
                            console.error(`Failed to refresh category: ${response.statusText}`);
                        }
                    } catch (error) {
                        console.error(`Error: ${error.message}`);
                    } finally {
                        button.disabled = false;
                        button.textContent = "Refresh";
                        document.querySelectorAll(`.refresh-feed[data-category-id='${categoryId}']`).forEach(feedButton => {
                            feedButton.disabled = false;
                            feedButton.textContent = "Refresh";
                        });
                    }
                });
            });

            document.querySelectorAll(".refresh-feed").forEach(button => {
                button.addEventListener("click", async (event) => {
                    const feedId = event.target.getAttribute("data-feed-id");
                    if (!feedId) return;

                    button.disabled = true;
                    button.textContent = "Refreshing...";
                    try {
                        const response = await fetch(`/api/feeds/${feedId}/refresh`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            }
                        });
                        if (response.ok) {
                            const result = await response.json();
                            console.log(`Feed refreshed successfully: ${JSON.stringify(result)}`);
                        } else {
                            console.error(`Failed to refresh feed: ${response.statusText}`);
                        }
                    } catch (error) {
                        console.error(`Error: ${error.message}`);
                    } finally {
                        button.disabled = false;
                        button.textContent = "Refresh";
                    }
                });
            });
        });
    </script>
</body>

</html>